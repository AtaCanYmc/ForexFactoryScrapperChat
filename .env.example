# .env.example - copy to .env and edit values as needed
# Host and port the Flask app will bind to
HOST=127.0.0.1
PORT=8080

# DEBUG: True/False (or 1/0)
DEBUG=True

# ForexFactoryScrapper API Base URL (if running separately)
FF_SCRAPPER_API_BASE_URL=http://127.0.0.1:5000

# Optional: specify a custom dotenv path
# DOTENV_PATH=/full/path/to/.env

# AI/LLM Configuration Examples
# Copy this file to .env and customize for your environment

# ============================================================================
# OPTION 1: Local Ollama (Development/Testing)
# ============================================================================
# Use this for local development with models like Qwen, Llama, etc.
# Make sure Ollama is running: https://ollama.ai

LLM_PROVIDER=ollama
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen:7b

# Other popular Ollama models:
# OLLAMA_MODEL=llama2
# OLLAMA_MODEL=mistral
# OLLAMA_MODEL=neural-chat

# ============================================================================
# OPTION 2: Groq Cloud API (Production - Fast Inference)
# ============================================================================
# Uncomment this section and comment out OPTION 1
# Get API key from: https://console.groq.com

# LLM_PROVIDER=groq
GROQ_API_KEY=your-api-key-here
GROQ_MODEL=mixtral-8x7b-32768
# Other Groq models: llama2-70b-4096, gemma-7b-it

# ============================================================================
# OPTION 3: OpenAI API (Production - GPT Models)
# ============================================================================
# Uncomment this section and comment out OPTION 1
# Get API key from: https://platform.openai.com/api-keys

# LLM_PROVIDER=openai
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4-turbo-preview
# Other OpenAI models: gpt-3.5-turbo, gpt-4


